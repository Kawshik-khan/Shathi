# Database (Supabase PostgreSQL)
# Format: postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_DB_PASSWORD=your-supabase-db-password

# Alternative: Direct Supabase Database URL (instead of individual components)
# SUPABASE_DB_URL=postgresql+asyncpg://postgres.your-project:your-db-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Hugging Face
HF_API_TOKEN=your-huggingface-token

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=sathi-memories
PINECONE_ENVIRONMENT=us-east-1

# Cloudflare KV
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_KV_NAMESPACE_ID=your-kv-namespace-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Application
APP_ENV=development
DEBUG=true
AUTO_CREATE_TABLES=false
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,https://localhost:3000

# Logging
LOG_LEVEL=INFO

