# Database (Supabase PostgreSQL)
# Local development default. Set DATABASE_URL to point at your new
# Supabase project (direct endpoint) when you want to run migrations
# locally.
# DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# Supabase Configuration — new project credentials.
# Get these from Supabase Dashboard -> Project Settings -> API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_DB_PASSWORD=your-supabase-db-password

# Supabase database connection string. Leave unset to fall back to
# DATABASE_URL. Two supported formats:
# - Pooler (transaction mode, recommended for the FastAPI app):
#     postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-<N>-<REGION>.pooler.supabase.com:6543/postgres
# - Direct (recommended for Alembic migrations):
#     postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
# SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Hugging Face
HF_API_TOKEN=your-huggingface-token

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=sathi-memories
PINECONE_ENVIRONMENT=us-east-1

# Redis Cache
# Local Redis: redis://localhost:6379/0
# Upstash Redis protocol: rediss://default:<password>@<host>:6379
REDIS_URL=redis://localhost:6379/0

# Chat Optimization
CHAT_HISTORY_LIMIT=12
EMBEDDING_TIMEOUT_SECONDS=3
USER_CONTEXT_CACHE_TTL=300

# Cloudflare KV
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_KV_NAMESPACE_ID=your-kv-namespace-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Application
APP_ENV=development
DEBUG=true
AUTO_CREATE_TABLES=false
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated list of exact origins (no wildcards). In production
# every origin MUST be https://; localhost is allowed only in development.
# Pinning concrete origins is required so credentialed cross-site requests
# from a malicious host cannot ride our Access-Control-Allow-Credentials
# header. P1 1.6.
CORS_ORIGINS=http://localhost:3000,https://shathi.vercel.app
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin,Referer,User-Agent,X-Requested-With,X-CSRF-Protection
CORS_EXPOSE_HEADERS=X-Request-ID,X-RateLimit-Remaining,X-RateLimit-Reset
CORS_MAX_AGE_SECONDS=600

# Logging
LOG_LEVEL=INFO
