# =============================================================================
# Sereni — Frontend Environment Variables
# Copy this file to .env.local for local development.
# On Vercel, set these in Project Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# NextAuth / Auth.js
# -----------------------------------------------------------------------------
# Secret used to sign session tokens. Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Canonical URL of the deployed frontend (no trailing slash).
# Vercel sets VERCEL_PROJECT_PRODUCTION_URL automatically; set this only if
# you use a custom domain.
NEXTAUTH_URL=https://your-app.vercel.app

# Google OAuth (optional — only needed if Google sign-in is enabled)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
# URL of the FastAPI backend deployed on Render (no trailing slash).
# Used server-side by the BFF proxy (/api/backend/proxy/[...path]).
BACKEND_API_URL=https://your-api.onrender.com

# Also exposed to the browser for direct client-side references (rare).
NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# -----------------------------------------------------------------------------
# Supabase (frontend client)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# -----------------------------------------------------------------------------
# Site URL (used for OG tags, canonical links, etc.)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# Security — BFF proxy verification key
# Must match SECRET_KEY set on the Render backend.
# -----------------------------------------------------------------------------
AUTH_PROXY_VERIFY_KEY=your-secret-key-here
